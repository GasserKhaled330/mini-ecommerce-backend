@Ecommerce.Api_HostAddress = http://localhost:5010
@ProductId = 3
@OrderId = 1

### US-01: Create a New Product
# Validates price > 0 and stock >= 0
POST {{Ecommerce.Api_HostAddress}}/api/products
Content-Type: application/json

{
  "name": "Gaming Mouse",
  "description": "RGB Wireless Gaming Mouse",
  "price": 59.99,
  "quantity": 50
}

### US-02: List Products (Paginated)
# Tests the PagedResponse wrapper
GET {{Ecommerce.Api_HostAddress}}/api/products?pageNumber=2&pageSize=6
Accept: application/json

### Get Product By ID
GET {{Ecommerce.Api_HostAddress}}/api/products/{{ProductId}}
Accept: application/json

### Update Product
PUT {{Ecommerce.Api_HostAddress}}/api/products/{{ProductId}}
Content-Type: application/json

{
  "name": "Gaming Mouse Pro",
  "description": "Updated RGB Wireless Gaming Mouse",
  "price": 65.00,
  "quantity": 45
}

### Delete Product
DELETE {{Ecommerce.Api_HostAddress}}/api/products/{{ProductId}}

### Test Validation: Create Product with Invalid Price (Should return 400)
POST {{Ecommerce.Api_HostAddress}}/api/products
Content-Type: application/json

{
  "name": "Broken Item",
  "description": "Invalid Price",
  "price": -10.00,
  "quantity": -1
}

### 1. Create a Valid Order (Happy Path)
# This should:
# - Subtract quantity from Product
# - Apply 5% discount if 2-4 items, 10% if 5+ (US-04)
# - Return 201 Created (US-03)
POST {{Ecommerce.Api_HostAddress}}/api/orders
Content-Type: application/json

{
  "customerName": "Jane Doe",
  "items": [
     
      "productId": {{ProductId}},
      "quantity": 3
    }
  ]
}

### 2. Get Order by ID (US-05)
# This should return the full receipt including DiscountAmount and TotalAmount
GET {{Ecommerce.Api_HostAddress}}/api/orders/{{OrderId}}
Accept: application/json

### 3. Create Order - Insufficient Stock (Conflict)
# Tests US-03: Try to buy 999 items
# Should return 409 Conflict via your Result Pattern
POST {{Ecommerce.Api_HostAddress}}/api/orders
Content-Type: application/json

{
  "customerName": "Bad Buyer",
  "items": [
    {
      "productId": {{ProductId}},
      "quantity": 999
    }
  ]
}

### 4. Create Order - Product Not Found
# Should return 404 Not Found
POST {{Ecommerce.Api_HostAddress}}/api/orders
Content-Type: application/json

{
  "customerName": "Ghost Buyer",
  "items": [
    {
      "productId": 9999,
      "quantity": 1
    }
  ]
}

### 5. Create Order - Validation Error (FluentValidation)
# Should return 400 Bad Request with your flattened Error string
POST {{Ecommerce.Api_HostAddress}}/api/orders
Content-Type: application/json

{
  "customerName": "",
  "items": []
}